# Google Gemini (Phase 1 scripts + Edge Function)
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
# Optional: override model (default gemini-2.5-flash-lite)
# GEMINI_MODEL=gemini-2.5-flash
# Free tier is ~10 requests/min. The puller caps Gemini calls per run and
# drains any backlog across cron ticks. Raise this if you upgrade Gemini billing.
# MAX_GEMINI_CALLS_PER_RUN=8

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Feed source (pick ONE) ---
# Preferred: Apify Facebook Posts Scraper (reliable, no item cap, ~free credit/mo).
# When APIFY_TOKEN is set, it takes priority over the RSS feed below.
APIFY_TOKEN=apify_api_...
ISECO_FB_PAGE_URL=https://www.facebook.com/ISECO.Official
# Optional overrides:
# APIFY_ACTOR_ID=apify~facebook-posts-scraper
# APIFY_RESULTS_LIMIT=20
# Only scrape posts newer than this window (absolute date, ISO timestamp, or
# relative like "14 days"). Keeps scrapes small and avoids parsing stale posts.
# ISECO_FETCH_WINDOW=14 days

# Fallback: ISECO Facebook RSS feed (from rss.app / FetchRSS). Used only if APIFY_TOKEN is empty.
ISECO_RSS_FEED_URL=https://rss.app/feeds/your-feed.xml

# Firebase Cloud Messaging (HTTP v1) for the Edge Function.
# Paste the FULL service-account JSON (Firebase Console → Project Settings →
# Service accounts → Generate new private key) as a single-line string.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}

# Optional: enable per-device barangay filtering for push notifications
USE_BARANGAY_FILTER=false

# apify Fetch window
ISECO_FETCH_WINDOW="7 days" 

FIREBASE_SERVICE_ACCOUNT= ""