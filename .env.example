# Google Gemini (Phase 1 scripts + Edge Function)
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
# Optional: override model (default gemini-2.5-flash-lite)
# GEMINI_MODEL=gemini-2.5-flash

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ISECO Facebook RSS feed (from rss.app or similar)
ISECO_RSS_FEED_URL=https://rss.app/feeds/your-feed.xml

# Firebase Cloud Messaging (legacy server key for Edge Function)
FCM_SERVER_KEY=AAAA...

# Optional: enable per-device barangay filtering for push notifications
USE_BARANGAY_FILTER=false
